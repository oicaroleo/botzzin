generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         String    @default("user")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bots         Bot[]
  gateways     GatewayConfig[]
  settings     UserSettings?
  flows        Flow[]

  @@index([email])
}

// ─── Bot (só token + metadados Telegram) ─────────────────────────────────────

model Bot {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name             String    @default("Meu Bot")
  telegramBotId    String    @unique
  telegramBotToken String    @unique
  telegramUsername String?
  status           String    @default("active") // active, paused

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  leads            Lead[]
  flowBots         FlowBot[]
  channels         BotChannel[]

  @@index([userId])
  @@index([status])
}

// ─── Canal/Grupo onde o bot é administrador (descoberto via my_chat_member) ──
// Usado para popular os selects de cache de mídia e entregáveis (sem ID manual).

model BotChannel {
  id      String @id @default(cuid())
  botId   String
  bot     Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  chatId  String  // ID do chat no Telegram (-100…)
  title   String?
  type    String  @default("channel") // channel | group | supergroup
  isAdmin Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, chatId])
  @@index([botId, isAdmin])
}

// ─── Gateway (nível de conta, não por bot) ───────────────────────────────────

model GatewayConfig {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider    String              // pushinpay, mercadopago, etc.
  apiKey      String
  displayName String?             // "Principal", "Backup Mercado Pago", etc.
  priority    Int      @default(0) // 0 = primário, 1 = fallback 1, 2 = fallback 2, ...
  isActive    Boolean  @default(true)

  // Estatísticas para A/B testing
  pixGenerated Int     @default(0)
  pixPaid      Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments    Payment[] // rastreia qual gateway gerou cada pagamento

  @@index([userId, priority])
  @@index([userId, isActive])
}

// ─── Configurações da conta ───────────────────────────────────────────────────

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A/B Testing: distribui PIX entre gateways e mede qual converte mais
  abTestEnabled               Boolean @default(false)

  // Inteligência da plataforma: usa dados agregados de TODOS os usuários
  // para auto-selecionar o gateway com maior conversão geral
  platformIntelligenceEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Estatísticas globais de gateway (todos os usuários) ─────────────────────

model PlatformGatewayStats {
  id           String   @id @default(cuid())
  provider     String   @unique
  pixGenerated Int      @default(0)
  pixPaid      Int      @default(0)
  // conversão = pixPaid / pixGenerated
  updatedAt    DateTime @updatedAt
}

// ─── Fluxo de automação ───────────────────────────────────────────────────────
// Um fluxo pode ser usado por múltiplos bots.
// Contém toda a configuração: mensagens, planos, entrega, upsell, downsell.

model Flow {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isActive    Boolean @default(true)

  // ── Mensagens ──
  welcomeMessage      String?   // /start
  welcomeMediaFileIds Json?     // mídias da boas-vindas (file_ids no canal de cache, até 3)
  pixMessage      String?   // após gerar PIX (padrão automático se vazio)
  confirmMessage  String?   // após confirmar pagamento

  // ── Bots / Distribuição / Cache de mídia ──
  mediaCacheChatId   String?  // canal/grupo onde o(s) bot(s) são admin; armazena mídias de prévia
  randomDistribution Boolean  @default(false) // distribui leads aleatoriamente entre os bots do fluxo
  redirectSlug       String?  @unique          // botzzin.com/redc_<slug> (link redirecionador)
  redirectDomain     String?                   // domínio próprio do dono da operação (futuro)

  // ── Entrega padrão ──
  deliveryType    String    @default("channel") // channel | group | link | message
  channelId       String?   // ID do canal/grupo (entrega via canal/grupo)
  deliveryValue   String?   // link ou texto da mensagem (entrega via link/message)

  // ── Renovação ──
  // Quantas horas antes de expirar o bot envia a oferta de renovação (com desconto por plano).
  renewalWarnHours Int      @default(24)

  // ── Variação de preço (anti-fraude: preço único por lead) ──
  // Quando ativo, soma um valor aleatório entre [min, max] ao preço de cada plano.
  // O valor é determinístico por lead — o mesmo lead sempre vê o mesmo preço.
  priceVariationEnabled Boolean @default(false)
  priceVariationMin     Float?  // ex.: 0.04
  priceVariationMax     Float?  // ex.: 1.00

  // ── Botão CTA (boas-vindas) ──
  // Desativado: fluxo padrão (boas-vindas → planos → gerar pix).
  // Ativado: botões customizados. ctaButtons = [{ label, action, value }]
  //   action ∈ plans | packs | external | vip | message
  ctaEnabled  Boolean @default(false)
  ctaButtons  Json?

  // ── Downsell ──
  downsellEnabled   Boolean @default(false)
  downsellMessage   String?
  downsellDelayMins Int?    @default(30) // quantos min após o gatilho inicia a esteira
  downsellDiscount  Float?              // % de desconto aplicado automaticamente
  downsellAdvanceRule String? @default("always")  // onlyIfPaid | always
  downsellTrigger     String? @default("both")    // pix_unpaid | start_unpaid | both
  downsellDeliveryType  String? // entrega global do downsell (null = mesma do fluxo)
  downsellDeliveryValue String?

  // ── Upsell (esteira para quem PAGOU) ──
  upsellEnabled     Boolean @default(false)
  upsellMessage     String? // legado / 1ª mensagem simples
  upsellDelayMins   Int?    @default(60)          // quanto tempo após o pagamento inicia a esteira
  upsellAdvanceRule String? @default("onlyIfPaid") // onlyIfPaid | always
  upsellDeliveryType  String? // entrega global do upsell (null = mesma do fluxo)
  upsellDeliveryValue String?

  // ── Order Bump (legado — multi-contexto agora em OrderBump) ──
  orderbumpEnabled Boolean @default(false)
  orderbumpMessage String?
  orderbumpPlanId  String? // plano do order bump

  // ── Order Bump: aplicar o do contexto "main" também nestes ──
  obApplyUpsell   Boolean @default(false)
  obApplyDownsell Boolean @default(false)
  obApplyPack     Boolean @default(false)

  // ── Configuração de pagamento (aba Pagamentos) ──
  // Blob com layout, texto/variáveis do PIX, botões, QR, prova social, etc.
  paymentConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bots        FlowBot[]
  plans       Plan[]
  funnelSteps FunnelStep[]
  orderBumps  OrderBump[]

  @@index([userId])
}

// ─── Order Bump (oferta extra antes de gerar o PIX) ──────────────────────────
// Um por contexto: fluxo principal, upsell, downsell ou pack.

model OrderBump {
  id          String  @id @default(cuid())
  flowId      String
  flow        Flow    @relation(fields: [flowId], references: [id], onDelete: Cascade)

  context     String  // main | upsell | downsell | pack
  enabled     Boolean @default(false)
  message     String? // descrição/mensagem do order bump (≤4000)

  // ── Produto do order bump (oferta própria, não atrelada a um Plan) ──
  name        String? // nome do produto
  price       Float?  // preço (R$)
  offerPlanId String? // (opcional) plano vinculado como order bump

  // ── Botões / CTA ──
  acceptLabel String? // texto do botão aceitar
  rejectLabel String? // texto do botão recusar
  hideReject  Boolean @default(false)
  ctaMessage  String? // mensagem CTA opcional

  // ── Mídia (file_ids no canal de cache) e entrega ──
  mediaFileIds  Json?   // array de file_ids (até 3)
  deliveryType  String? // null = usa entrega do fluxo principal | channel | group | link | message
  deliveryValue String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([flowId, context])
}

// ─── Passo de esteira (upsell / downsell) ─────────────────────────────────────

model FunnelStep {
  id        String  @id @default(cuid())
  flowId    String
  flow      Flow    @relation(fields: [flowId], references: [id], onDelete: Cascade)

  kind        String  // upsell | downsell
  order       Int     @default(0)
  delayMins   Int     @default(60) // após o passo anterior (ou após o gatilho, no 1º)
  message     String
  planId      String? // oferta opcional de plano (legado / single)
  mediaFileId String? // legado (1 mídia)

  // ── Sequência completa (estilo concorrente) ──
  sendTiming    String  @default("delay")  // immediate | delay
  discountType  String? // percent | value
  discountValue Float?
  planIds       Json?   // múltiplos planos da oferta (com desconto)
  acceptLabel   String?
  rejectLabel   String?
  hideReject    Boolean @default(false)
  mediaFileIds  Json?   // até 3 mídias (file_ids no cache)
  deliveryType  String? // null = usa entrega global do upsell/downsell
  deliveryValue String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([flowId, kind, order])
}

// ─── Associação Bot ↔ Fluxo (N:1 — cada bot pertence a no máximo 1 fluxo) ───

model FlowBot {
  id     String @id @default(cuid())
  flowId String
  flow   Flow   @relation(fields: [flowId], references: [id], onDelete: Cascade)
  botId  String @unique // um bot só pode estar em um fluxo
  bot    Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([flowId])
}

// ─── Plano (pertence a um Flow) ───────────────────────────────────────────────

model Plan {
  id          String  @id @default(cuid())
  flowId      String
  flow        Flow    @relation(fields: [flowId], references: [id], onDelete: Cascade)

  name        String
  description String?
  days        Int
  price       Float
  emoji       String  @default("💎")
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  // ── Entregável do plano ──
  // Por padrão usa a entrega padrão do fluxo. Pode ser sobrescrito por plano.
  useDefaultDelivery Boolean @default(true)
  deliveryType       String? // channel | group | link | message
  deliveryValue      String? // channelId, link ou texto da mensagem

  // ── Renovação ──
  // Desconto (%) aplicado ao preço quando o lead renova via oferta de renovação.
  renewalDiscount    Float   @default(0) // 0–100 (%)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  payments    Payment[]

  @@index([flowId, isActive])
}

// ─── Lead ─────────────────────────────────────────────────────────────────────

model Lead {
  id               String    @id @default(cuid())
  botId            String
  bot              Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  flowId           String?   // fluxo no momento da interação (para analytics)

  telegramUserId   String
  telegramUsername String?
  firstName        String?

  status           String    @default("started") // started | pix_generated | paid | expired

  pixCount         Int       @default(0)
  starts           Int       @default(1) // quantas vezes deu /start

  paidAt           DateTime?
  accessExpiresAt  DateTime?
  renewalWarnedAt  DateTime? // quando a oferta de renovação foi enviada (evita duplicar)
  removedAt        DateTime? // quando o lead foi removido do canal por expiração
  blockedAt        DateTime? // quando o lead bloqueou o bot (my_chat_member kicked no privado)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  payments         Payment[]
  events           LeadEvent[]
  funnelProgress   FunnelProgress[]

  @@unique([botId, telegramUserId])
  @@index([botId, status])
  @@index([flowId])
  @@index([createdAt])
}

// ─── Progresso da esteira (upsell/downsell) por lead ────────────────────────────
model FunnelProgress {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  kind      String   // upsell | downsell
  nextOrder Int      @default(0)   // índice do próximo step a enviar
  sendAt    DateTime                // quando enviar o próximo step
  status    String   @default("active") // active | done | stopped
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leadId, kind])
  @@index([status, sendAt])
}

// ─── Timeline do lead (log enxuto de marcos do ciclo de vida) ───────────────────
model LeadEvent {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   // started | plan_selected | pix_generated | paid | access_granted | renewal_offered | access_expired | removed | blocked
  meta      Json?    // dados mínimos: {planId,planName,amount,paymentId,e2e,channelId,days,expiresAt}
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

// ─── Pagamento ────────────────────────────────────────────────────────────────

model Payment {
  id          String  @id @default(cuid())
  leadId      String
  lead        Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  planId      String
  plan        Plan    @relation(fields: [planId], references: [id])

  // Gateway que gerou este PIX (para tracking de A/B)
  gatewayConfigId String?
  gatewayConfig   GatewayConfig? @relation(fields: [gatewayConfigId], references: [id])

  amount      Float
  gateway     String              // "pushinpay"
  gatewayTxId String?   @unique
  endToEndId  String?             // código E2E do PIX pago (defesa MED/chargeback)
  funnelStepId String?            // step da esteira que gerou esta compra (override de entrega)

  status      String    @default("pending") // pending | paid | expired | failed

  qrCode      String?
  copyPaste   String?

  expiresAt   DateTime?
  paidAt      DateTime?

  webhookData Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([leadId])
  @@index([status])
  @@index([gatewayConfigId])
  @@index([endToEndId])
}
